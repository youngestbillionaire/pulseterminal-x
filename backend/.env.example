# ─── App ─────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3001
LOG_LEVEL=debug

# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://ptuser:ptpassword@localhost:5432/pulseterminal"

# ─── Redis ───────────────────────────────────────────────────────────────────
REDIS_URL="redis://localhost:6379"
REDIS_HOST=localhost
REDIS_PORT=6379

# ─── JWT ─────────────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
JWT_SECRET="change-me-use-openssl-rand-hex-32-minimum-32-chars"
JWT_REFRESH_SECRET="change-me-different-secret-also-32-chars-minimum"

# ─── Frontend ─────────────────────────────────────────────────────────────────
FRONTEND_URL="http://localhost:3000"

# ─── Stripe ──────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
STRIPE_PRO_PRICE_ID="price_..."
STRIPE_ELITE_PRICE_ID="price_..."

# ─── Internal service auth ────────────────────────────────────────────────────
# Must match INTERNAL_API_KEY in intelligence service
INTERNAL_API_KEY="change-me-internal-service-key-32-chars"

# ─── Intelligence Service ─────────────────────────────────────────────────────
INTELLIGENCE_SERVICE_URL="http://localhost:8001"

# ─── Email (Nodemailer) ───────────────────────────────────────────────────────
SMTP_HOST="smtp.resend.com"
SMTP_PORT=465
SMTP_USER="resend"
SMTP_PASS="re_..."
EMAIL_FROM="PulseTerminal X <noreply@yourdomain.com>"
