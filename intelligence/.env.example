# ─── App ─────────────────────────────────────────────────────────────────────
APP_ENV=development
LOG_LEVEL=INFO

# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql+asyncpg://ptuser:ptpassword@localhost:5432/pulseterminal"

# ─── Redis ───────────────────────────────────────────────────────────────────
REDIS_URL="redis://localhost:6379"

# ─── Internal Auth ────────────────────────────────────────────────────────────
# Must match INTERNAL_API_KEY in backend service
INTERNAL_API_KEY="change-me-internal-service-key-32-chars"

# ─── LLM APIs ────────────────────────────────────────────────────────────────
LLM_PROVIDER=anthropic         # anthropic | openai
ANTHROPIC_API_KEY="sk-ant-..."
OPENAI_API_KEY="sk-..."

# ─── Reddit (PRAW) ────────────────────────────────────────────────────────────
# Create app at https://www.reddit.com/prefs/apps
REDDIT_CLIENT_ID="your_reddit_client_id"
REDDIT_CLIENT_SECRET="your_reddit_client_secret"
REDDIT_USER_AGENT="PulseTerminalX/1.0 (by /u/yourusername)"

# ─── News ─────────────────────────────────────────────────────────────────────
NEWS_API_KEY="your_newsapi_key"       # https://newsapi.org
ALPHA_VANTAGE_KEY="your_av_key"       # https://www.alphavantage.co
POLYGON_API_KEY="your_polygon_key"    # https://polygon.io

# ─── Sentiment Model ──────────────────────────────────────────────────────────
SENTIMENT_MODEL=ProsusAI/finbert      # HuggingFace model
USE_GPU=false                          # Set true if CUDA available
